# Список серверов (JSON-массив).
#
# Обязательное поле: host
# Опциональные поля:
#   user       — SSH-пользователь (default: root)
#   password   — SSH-пароль (оставь пустым для аутентификации по ключу)
#   domain     — домен для TLS (без него работает только Reality)
#   stack_path — путь к стеку на этом сервере (переопределяет глобальный STACK_PATH)
#
# Примеры:
#
# Один сервер с доменом:
# SERVERS=[{"host":"1.2.3.4","user":"root","domain":"vpn.example.com"}]
#
# Два сервера, у одного нет домена:
# SERVERS=[{"host":"1.2.3.4","user":"root","domain":"vpn.example.com"},{"host":"5.6.7.8","user":"root"}]
#
# Сервер с паролем и кастомным путём стека:
# SERVERS=[{"host":"1.2.3.4","user":"ubuntu","password":"secret","domain":"vpn.example.com","stack_path":"/opt/xray"}]

SERVERS=[{"host":"your-server-ip","user":"root","domain":"your-domain.com"}]

# Путь к стеку по умолчанию (создаётся автоматически).
# Можно переопределить на уровне конкретного сервера в SERVERS.
STACK_PATH=~/xray-server

# Email для Let's Encrypt — общий для всех серверов.
# Обязателен если хотя бы у одного сервера задан domain.
CERTBOT_EMAIL=your@email.com
